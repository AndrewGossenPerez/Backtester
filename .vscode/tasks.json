{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build TradingEngine",
      "type": "process",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -e; mkdir -p build; SRC_FILES=$(find src -name \"*.cpp\" ! -name \"binding.cpp\" -print); clang++ -std=c++17 -Wall -Wextra -g -Iinclude $SRC_FILES -o build/engine"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run TradingEngine",
      "type": "process",
      "command": "/bin/bash",
      "args": ["-lc", "./build/engine"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Build TradingEngine",
      "group": "test"
    },

    {
      "label": "Build Pybind Module (CMake)",
      "type": "process",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -e; cmake -S . -B build_py -DCMAKE_BUILD_TYPE=Release; cmake --build build_py -j"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$gcc"]
    },

    {
      "type": "cppbuild",
      "label": "C/C++: clang++ build active file",
      "command": "/usr/bin/clang++",
      "args": [
        "-fcolor-diagnostics",
        "-fansi-escape-codes",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    },
    {
  "label": "Build & Run Pybind",
  "type": "process",
  "command": "/bin/bash",
  "args": [
    "-lc",
    "source .venv/bin/activate && cmake --build build_py -j && PYTHONPATH=\"$PWD/build_py:$PWD/python\" python python/test.py"
  ],
  "options": {
    "cwd": "${workspaceFolder}"
  },
  "group": {
    "kind": "build",
    "isDefault": false
  },
  "problemMatcher": ["$gcc"]
}

  ]
}
